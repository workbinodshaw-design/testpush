rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default DENY ALL to ensure strict whitelisting
    match /{document=**} {
      allow read, write: if false;
    }
    
    // --- ANALYTICS ---
    // Only allow incrementing analytics, prevent overwriting or deleting
    match /analytics/{document=**} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalVisitors', 'lastVisit']) 
                    && request.resource.data.totalVisitors == resource.data.totalVisitors + 1;
      allow create: if true;
    }
    match /analytics_daily/{document=**} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'date']) 
                    && request.resource.data.count == resource.data.count + 1;
      allow create: if true;
    }

    // --- ADMIN DEFINITION ---
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "work.binodshaw@gmail.com";
    }

    // --- TOOLS (LIVE COMMUNITY & ADMIN TOOLS) ---
    match /tools/{toolId} {
      allow read: if true; // Public can see tools
      // Allow authenticated users to increment upvotes
      allow update: if request.auth != null 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes'])
                    && request.resource.data.upvotes == resource.data.upvotes + 1;
      // Only Admin can create, fully update, or delete tools directly
      allow write: if isAdmin();
      
      // Nested upvotes collection for tracking who voted
      match /upvotes/{userId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // --- SUBMISSIONS (PENDING COMMUNITY TOOLS) ---
    match /submissions/{subId} {
      // Admins can read all submissions to approve/reject them
      allow read: if isAdmin();
      // Authenticated users can submit tools. We enforce their UID matches the document.
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // --- NEWSLETTER SUBSCRIBERS ---
    match /subscribers/{email} {
      // Admins can read the subscriber list
      allow read, delete: if isAdmin();
      // Anyone can subscribe (add their email)
      allow create: if true;
      allow update: if false; // No updating emails once subscribed
    }

    // --- FEEDBACK ---
    match /feedback/{feedbackId} {
      // Admins can read and delete feedback
      allow read, delete: if isAdmin();
      // Anyone can submit feedback
      allow create: if true;
      allow update: if false; // No editing feedback
    }
    
    // --- USERS (PROFILES & BOOKMARKS) ---
    match /users/{userId} {
      // Only the specific user can read/write their own profile/bookmarks
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
